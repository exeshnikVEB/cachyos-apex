# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# How often to check Steam for new deals (in seconds, default: 3600 = 1 hour)
CHECK_INTERVAL=3600

# Minimum discount percentage to notify about (default: 50)
MIN_DISCOUNT=50

# Max games to fetch per check (default: 100)
MAX_GAMES=100
